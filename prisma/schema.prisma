
  generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
  }

  model Produto {
    id      String @id @default(uuid())
    nome    String
    marca   String
    peso    Float
    porte   String
    preco   Float
    estoque Int
  }

  model Usuario {
    id       String @id @default(uuid())
    nome     String
    email    String @unique
    senha    String
    createdAt DateTime @default(now())
  }
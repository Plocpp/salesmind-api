
  generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
  }

  model Produto {
    id           String   @id @default(uuid())
    nome         String
    peso         Float
    porte        String
    preco        Float
    precoCusto   Float?
    estoque      Int

    codigo       String?  @unique
    codigoBarras String?  @unique
    cor          String?
    tamanho      String?
    validade     DateTime?

    // 🔐 RELAÇÕES OBRIGATÓRIAS
    usuarioId    String
    marcaId      String

    usuario      Usuario @relation(fields: [usuarioId], references: [id])
    marca        Marca   @relation(fields: [marcaId], references: [id])

    itensVenda   ItemVenda[]

    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
  }

  model Usuario {
    id           String   @id @default(uuid())
    nome         String
    email        String   @unique
    senha        String
    role         Role     @default(USER)

    refreshToken String?  @db.Text

    produtos     Produto[]
    vendas       Venda[]

    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
  }

  model Cliente {
    id        String   @id @default(uuid())
    nome      String
    telefone  String?
    email     String?  @unique

    vendas    Venda[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }

  model Fornecedor {
    id        String   @id @default(uuid())
    nome      String
    cnpj      String?  @unique
    telefone  String?
    email     String?
    endereco  String?

    marcas    Marca[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }

  model Marca {
    id           String   @id @default(uuid())
    nome         String   @unique
    fornecedorId String

    fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
    produtos     Produto[]

    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
  }

  model Venda {
    id        String   @id @default(uuid())
    data      DateTime @default(now())
    total     Float

    usuarioId String
    clienteId String?

    usuario   Usuario @relation(fields: [usuarioId], references: [id])
    cliente   Cliente? @relation(fields: [clienteId], references: [id])

    itens     ItemVenda[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }

  model ItemVenda {
    id             String  @id @default(uuid())
    quantidade     Float
    precoUnitario  Float
    desconto       Float   @default(0)

    vendaId        String
    produtoId      String

    venda          Venda   @relation(fields: [vendaId], references: [id])
    produto        Produto @relation(fields: [produtoId], references: [id])
  }
  enum Role {
    USER
    ADMIN
  }
# ===============================================
# SaaS Onboarding por Pagamento (Multiempresa)
# ===============================================

# Base publica para links de mock checkout
PUBLIC_BASE_URL=http://localhost:3000

# Token usado para autenticar webhook de pagamento
ONBOARDING_WEBHOOK_TOKEN=troque-por-um-token-forte

# -----------------------------------------------
# E-mail (ativação e recuperação de senha)
# Para Outlook/Microsoft 365 use EMAIL_PROVIDER=outlook
# -----------------------------------------------
EMAIL_MOCK_MODE=true
EMAIL_PROVIDER=outlook
EMAIL_FROM=no-reply@seu-dominio.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ACCESS_CODE_TTL_MINUTES=20
EMAIL_DEV_RETURN_CODE=false

# -----------------------------------------------
# SMS / WhatsApp via Twilio
# Configure essas variáveis para enviar códigos reais por telefone.
# Se PHONE_MOCK_MODE=true, o envio será apenas em modo mock.
# -----------------------------------------------
PHONE_MOCK_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
PHONE_DEV_RETURN_CODE=false

# -----------------------------------------------
# Checkout links por provedor/plano
# Configure com links reais do seu gateway
# -----------------------------------------------

# ASAAS
SAAS_CHECKOUT_LINK_ASAAS_STARTER=
SAAS_CHECKOUT_LINK_ASAAS_GROWTH=
SAAS_CHECKOUT_LINK_ASAAS_SCALE=

# MERCADO PAGO
SAAS_CHECKOUT_LINK_MERCADO_PAGO_STARTER=
SAAS_CHECKOUT_LINK_MERCADO_PAGO_GROWTH=
SAAS_CHECKOUT_LINK_MERCADO_PAGO_SCALE=

# STRIPE
SAAS_CHECKOUT_LINK_STRIPE_STARTER=
SAAS_CHECKOUT_LINK_STRIPE_GROWTH=
SAAS_CHECKOUT_LINK_STRIPE_SCALE=

# PAYPAL
SAAS_CHECKOUT_LINK_PAYPAL_STARTER=
SAAS_CHECKOUT_LINK_PAYPAL_GROWTH=
SAAS_CHECKOUT_LINK_PAYPAL_SCALE=

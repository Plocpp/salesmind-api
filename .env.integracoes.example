# ======================================================
# SalesMind - Exemplo de variaveis para Integracoes HUB
# ======================================================

# Base publica da API para templates de webhook
PUBLIC_BASE_URL=https://api.seudominio.com

# Base do frontend para redirecionamento apos callback OAuth
FRONTEND_BASE_URL=https://app.seudominio.com

# Chave para criptografia local de payloads de token no banco
INTEGRACOES_ENCRYPTION_KEY=troque-esta-chave-por-uma-segura

# Fallback global para redirect_uri OAuth
INTEGRACAO_DEFAULT_REDIRECT_URI=https://api.seudominio.com/integracoes/callback/default

# -----------------------------
# Mercado Livre (OAuth)
# -----------------------------
INTEGRACAO_MERCADO_LIVRE_CLIENT_ID=
INTEGRACAO_MERCADO_LIVRE_CLIENT_SECRET=
INTEGRACAO_MERCADO_LIVRE_REDIRECT_URI=https://api.seudominio.com/integracoes/callback/mercado-livre
INTEGRACAO_MERCADO_LIVRE_SCOPE=read write offline_access

# -----------------------------
# Shopify (OAuth por loja)
# -----------------------------
INTEGRACAO_SHOPIFY_CLIENT_ID=
INTEGRACAO_SHOPIFY_CLIENT_SECRET=
INTEGRACAO_SHOPIFY_REDIRECT_URI=https://api.seudominio.com/integracoes/callback/shopify
INTEGRACAO_SHOPIFY_SCOPE=read_products write_products read_orders write_orders

# -----------------------------
# Nuvemshop (OAuth)
# -----------------------------
INTEGRACAO_NUVEMSHOP_CLIENT_ID=
INTEGRACAO_NUVEMSHOP_CLIENT_SECRET=
INTEGRACAO_NUVEMSHOP_REDIRECT_URI=https://api.seudominio.com/integracoes/callback/nuvemshop
INTEGRACAO_NUVEMSHOP_SCOPE=read_products write_products read_orders

# -----------------------------
# Mercado Pago (OAuth)
# -----------------------------
INTEGRACAO_MERCADO_PAGO_CLIENT_ID=
INTEGRACAO_MERCADO_PAGO_CLIENT_SECRET=
INTEGRACAO_MERCADO_PAGO_REDIRECT_URI=https://api.seudominio.com/integracoes/callback/mercado-pago
INTEGRACAO_MERCADO_PAGO_SCOPE=payments read write

# -----------------------------
# PayPal (OAuth)
# -----------------------------
INTEGRACAO_PAYPAL_CLIENT_ID=
INTEGRACAO_PAYPAL_CLIENT_SECRET=
INTEGRACAO_PAYPAL_REDIRECT_URI=https://api.seudominio.com/integracoes/callback/paypal
INTEGRACAO_PAYPAL_SCOPE=openid profile email

# -----------------------------
# Stripe (API Key)
# -----------------------------
INTEGRACAO_STRIPE_API_KEY=
INTEGRACAO_STRIPE_TOKEN=

# -----------------------------
# Asaas (API Key)
# -----------------------------
INTEGRACAO_ASAAS_API_KEY=
INTEGRACAO_ASAAS_TOKEN=

# -----------------------------
# WooCommerce (API Key/Token)
# -----------------------------
INTEGRACAO_WOO_COMMERCE_API_KEY=
INTEGRACAO_WOO_COMMERCE_TOKEN=

# -----------------------------
# VTEX (API Key/Token)
# -----------------------------
INTEGRACAO_VTEX_API_KEY=
INTEGRACAO_VTEX_TOKEN=
